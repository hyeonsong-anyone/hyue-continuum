# Supabase (방명록 저장)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 방명록 IP 해시 솔트 (rate limit / 개인정보 최소화용)
GUESTBOOK_IP_SALT=change-me-to-a-random-string

# 네이버 지도 Dynamic Map Client ID (ncpKeyId). 도메인 제한 공개 키.
# 미설정 시 지도는 '네이버 지도에서 보기' 링크로 폴백.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
